# CyberDope Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/cyberdope

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenAI API (for AI features)
OPENAI_API_KEY=your-openai-api-key

# Cloudinary (for image/video uploads in production)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Web3/WalletConnect (for crypto payments)
WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Redis (for caching and sessions - optional)
REDIS_URL=redis://localhost:6379
